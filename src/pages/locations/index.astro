---
import Base from '../../layouts/Base.astro';
import AreaCard from '../../components/AreaCard.astro';
import LocalBusiness from '../../components/schema/LocalBusiness.astro';
import { config } from '../../lib/config';
const title = `Service Areas | ${config.business_name}`;
const description = `${config.niche} coverage across ${config.city} and surrounding areas.`;
---
<Base title={title} description={description}>
  <Fragment slot="head"><LocalBusiness /></Fragment>
  <section class="max-w-5xl mx-auto px-4 py-12">
    <h1 class="text-3xl font-bold">Areas We Serve</h1>
    <div class="grid grid-cols-2 md:grid-cols-4 gap-3 mt-8">
      <AreaCard name={config.city} />
      {config.service_areas.map((a: string) => <AreaCard name={a} />)}
    </div>
  </section>
</Base>
