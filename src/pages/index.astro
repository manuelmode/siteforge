---
import Base from '../layouts/Base.astro';
import HeroBlock from '../components/HeroBlock.astro';
import ServiceCard from '../components/ServiceCard.astro';
import AreaCard from '../components/AreaCard.astro';
import CallButton from '../components/CallButton.astro';
import LocalBusiness from '../components/schema/LocalBusiness.astro';
import { config } from '../lib/config';
const title = `${config.niche} ${config.city}, ${config.state_abbr} | ${config.business_name}`;
const description = `${config.niche} in ${config.city}. Fast, honest, mobile when possible. Call ${config.tracking_phone_display} for a free quote.`;
---
<Base title={title} description={description} canonical={`https://${config.domain}/`}>
  <Fragment slot="head">
    <LocalBusiness />
  </Fragment>
  <HeroBlock />
  <section class="max-w-5xl mx-auto px-4 py-12">
    <h2 class="text-2xl font-bold mb-6">Our Services</h2>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-3">
      {config.services.map((s) => <ServiceCard name={s} />)}
    </div>
  </section>
  <section class="bg-slate-50 py-12">
    <div class="max-w-5xl mx-auto px-4">
      <h2 class="text-2xl font-bold mb-6">Areas We Serve</h2>
      <div class="grid grid-cols-2 md:grid-cols-4 gap-3">
        <AreaCard name={config.city} />
        {config.service_areas.map((a) => <AreaCard name={a} />)}
      </div>
    </div>
  </section>
  <CallButton />
</Base>
