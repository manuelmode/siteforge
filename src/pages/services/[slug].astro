---
import { getCollection, render } from 'astro:content';
import { Image } from 'astro:assets';
import Base from '../../layouts/Base.astro';
import CallButton from '../../components/CallButton.astro';
import FAQSection from '../../components/FAQSection.astro';
import LocalBusiness from '../../components/schema/LocalBusiness.astro';
import ServiceSchema from '../../components/schema/Service.astro';
import Breadcrumb from '../../components/schema/Breadcrumb.astro';
import { config } from '../../lib/config';
import { slugify } from '../../lib/slug';

export async function getStaticPaths() {
  const entries = await getCollection('services');
  const entryBySlug = new Map(entries.map((e) => [e.id, e]));
  return config.services.map((service: string) => {
    const slug = slugify(service);
    return {
      params: { slug },
      props: { service, entry: entryBySlug.get(slug) ?? null },
    };
  });
}
const { service, entry } = Astro.props;
const title = `${service} in ${config.city}, ${config.state_abbr} | ${config.business_name}`;
const description = `${service} in ${config.city}. Call ${config.tracking_phone_display} for a free quote.`;
const url = `https://${config.domain}/services/${Astro.params.slug}/`;
const crumbs = [
  { name: 'Home', url: `https://${config.domain}/` },
  { name: 'Services', url: `https://${config.domain}/services/` },
  { name: service, url },
];
const Content = entry ? (await render(entry)).Content : null;
const heroImg = entry?.data.hero_image;
const heroAlt = entry?.data.hero_alt ?? `${service} in ${config.city}, ${config.state_abbr}`;
const faqs = entry?.data.faqs ?? [];
---
<Base title={title} description={description} canonical={url}>
  <Fragment slot="head">
    <LocalBusiness />
    <ServiceSchema name={service} description={description} />
    <Breadcrumb crumbs={crumbs} />
  </Fragment>
  {heroImg && (
    <figure class="max-w-5xl mx-auto px-4 pt-8">
      <Image src={heroImg} alt={heroAlt}
             widths={[640, 960, 1280, 1600]}
             sizes="(min-width: 1024px) 1024px, 100vw"
             class="w-full h-64 md:h-96 object-cover rounded-lg shadow-sm"
             loading="eager" />
    </figure>
  )}
  <article class="max-w-3xl mx-auto px-4 py-12 prose prose-slate">
    <h1>{service} in {config.city}</h1>
    <p class="lead">{description}</p>
    {Content && <Content />}
    {faqs.length > 0 && <FAQSection items={faqs} />}
    <p class="mt-8">
      For a free assessment, call
      <a href={`tel:${config.tracking_phone}`}>{config.tracking_phone_display}</a>.
    </p>
  </article>
  <CallButton />
</Base>
