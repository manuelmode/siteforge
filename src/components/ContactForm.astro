---
import { config } from '../lib/config';
const action = `https://forms.${config.domain}/submit`;
---
<form action={action} method="POST" class="space-y-3">
  <input type="text" name="name" required placeholder="Your name" class="w-full border rounded p-2" />
  <input type="tel" name="phone" required placeholder="Phone number" class="w-full border rounded p-2" />
  <input type="email" name="email" placeholder="Email (optional)" class="w-full border rounded p-2" />
  <textarea name="message" rows="3" placeholder="Brief description of what you need" class="w-full border rounded p-2"></textarea>
  <input type="hidden" name="_form_email" value={config.form_email} />
  <button type="submit" class="bg-emerald-600 text-white px-5 py-2 rounded font-semibold">Get a Free Quote</button>
</form>
<p class="text-xs text-slate-500 mt-2">Or call <a href={`tel:${config.tracking_phone}`} class="text-emerald-700 font-semibold">{config.tracking_phone_display}</a> directly.</p>
