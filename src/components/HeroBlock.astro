---
import { config } from '../lib/config';
interface Props {
  headline?: string;
  subheadline?: string;
}
const { headline, subheadline } = Astro.props;
const h = headline ?? `${config.niche} in ${config.city}`;
const s = subheadline ?? `Fast, honest service. Mobile when possible. Free quote.`;
---
<section class="bg-slate-900 text-white">
  <div class="max-w-5xl mx-auto px-4 py-16">
    <h1 class="text-4xl md:text-5xl font-bold leading-tight">{h}</h1>
    <p class="mt-4 text-lg text-slate-300">{s}</p>
    <a href={`tel:${config.tracking_phone}`} class="inline-block mt-6 bg-emerald-500 text-slate-900 px-6 py-3 rounded font-bold">
      Call {config.tracking_phone_display}
    </a>
  </div>
</section>
