---
import { Image } from 'astro:assets';
import { config } from '../lib/config';
// Per-site hero image lives at src/assets/heros/hero.jpg by convention.
// Each BUILD-N spawn drops its own hero.jpg into that path.
import heroImg from '../assets/heros/hero.jpg';

interface Props {
  headline?: string;
  subheadline?: string;
}
const { headline, subheadline } = Astro.props;
const h = headline ?? `${config.niche} in ${config.city}`;
const s = subheadline ?? `Fast, honest service. Mobile when possible. Free quote.`;
const heroAlt = config.hero_image_alt ?? `${config.niche} in ${config.city}, ${config.state_abbr}`;
---
<section class="relative bg-slate-900 text-white overflow-hidden">
  <Image src={heroImg} alt={heroAlt}
         widths={[640, 960, 1280, 1600, 1920]}
         sizes="100vw"
         class="absolute inset-0 w-full h-full object-cover opacity-40"
         loading="eager" />
  <div class="relative max-w-5xl mx-auto px-4 py-20 md:py-28">
    <h1 class="text-4xl md:text-5xl font-bold leading-tight drop-shadow-md">{h}</h1>
    <p class="mt-4 text-lg text-slate-200 max-w-2xl">{s}</p>
    <a href={`tel:${config.tracking_phone}`}
       class="inline-block mt-6 bg-amber-500 hover:bg-amber-400 transition-colors text-slate-900 px-6 py-3 rounded font-bold shadow-lg">
      Call {config.tracking_phone_display}
    </a>
  </div>
</section>
