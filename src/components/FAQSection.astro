---
interface Q { question: string; answer: string; }
interface Props {
  heading?: string;
  items: Q[];
}
const { heading = 'Frequently asked questions', items } = Astro.props;
const schema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": items.map(({ question, answer }) => ({
    "@type": "Question",
    "name": question,
    "acceptedAnswer": { "@type": "Answer", "text": answer }
  }))
};
---
<section class="not-prose my-12 border-t border-slate-200 pt-10">
  <h2 class="text-2xl font-bold mb-6">{heading}</h2>
  <div class="space-y-3">
    {items.map(({ question, answer }) => (
      <details class="group border border-slate-200 rounded-md bg-white">
        <summary class="cursor-pointer list-none px-4 py-3 font-semibold text-slate-900 flex items-center justify-between hover:bg-slate-50 transition-colors">
          <span>{question}</span>
          <svg class="w-5 h-5 text-slate-400 transition-transform group-open:rotate-180" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
            <path fill-rule="evenodd" d="M5.23 7.21a.75.75 0 0 1 1.06.02L10 11.06l3.71-3.83a.75.75 0 1 1 1.08 1.04l-4.25 4.4a.75.75 0 0 1-1.08 0l-4.25-4.4a.75.75 0 0 1 .02-1.06z" clip-rule="evenodd"/>
          </svg>
        </summary>
        <div class="px-4 pb-4 pt-1 text-slate-700 leading-relaxed">{answer}</div>
      </details>
    ))}
  </div>
</section>
<script type="application/ld+json" set:html={JSON.stringify(schema)}></script>
