---
import { config } from '../lib/config';
import Logo from './Logo.astro';
---
<header class="border-b border-slate-200 bg-white">
  <div class="max-w-5xl mx-auto px-4 py-4 flex items-center justify-between gap-4">
    <Logo />
    <nav class="hidden md:flex gap-6 text-sm text-slate-700">
      <a href="/services/" class="hover:text-teal-700 transition-colors">Services</a>
      <a href="/locations/" class="hover:text-teal-700 transition-colors">Areas</a>
      <a href="/articles/" class="hover:text-teal-700 transition-colors">Articles</a>
      <a href="/about/" class="hover:text-teal-700 transition-colors">About</a>
      <a href="/contact/" class="hover:text-teal-700 transition-colors">Contact</a>
    </nav>
    <a href={`tel:${config.tracking_phone}`}
       class="bg-teal-700 hover:bg-teal-800 transition-colors text-white px-4 py-2 rounded font-semibold text-sm whitespace-nowrap">
      {config.tracking_phone_display}
    </a>
  </div>
</header>
