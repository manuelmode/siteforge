---
import { config } from '../lib/config';
---
<header class="border-b border-slate-200">
  <div class="max-w-5xl mx-auto px-4 py-4 flex items-center justify-between">
    <a href="/" class="font-bold text-lg">{config.business_name}</a>
    <nav class="hidden md:flex gap-6 text-sm">
      <a href="/services/">Services</a>
      <a href="/locations/">Areas</a>
      <a href="/about/">About</a>
      <a href="/contact/">Contact</a>
    </nav>
    <a href={`tel:${config.tracking_phone}`} class="bg-emerald-600 text-white px-4 py-2 rounded font-semibold text-sm">
      {config.tracking_phone_display}
    </a>
  </div>
</header>
