---
interface Crumb {
  name: string;
  url: string;
}
interface Props {
  crumbs: Crumb[];
}
const { crumbs } = Astro.props;
const data = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: crumbs.map((c, i) => ({
    '@type': 'ListItem',
    position: i + 1,
    name: c.name,
    item: c.url,
  })),
};
---
<script type="application/ld+json" set:html={JSON.stringify(data)}></script>
