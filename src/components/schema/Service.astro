---
import { config } from '../../lib/config';
interface Props {
  name: string;
  description: string;
}
const { name, description } = Astro.props;
const data = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  name,
  description,
  provider: {
    '@type': config.schema.type,
    name: config.business_name,
    telephone: config.tracking_phone,
  },
  areaServed: { '@type': 'City', name: config.city },
};
---
<script type="application/ld+json" set:html={JSON.stringify(data)}></script>
