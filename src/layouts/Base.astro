---
import '../styles/global.css';
import { ClientRouter } from 'astro:transitions';
import { config } from '../lib/config';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title: string;
  description: string;
  canonical?: string;
}
const { title, description, canonical } = Astro.props;
const ogImage = config.og_image_path ? `${Astro.site}${config.og_image_path.replace(/^\//, '')}` : null;
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <link rel="preload" as="font" type="font/woff2" href="/fonts/InterVariable.woff2" crossorigin />
  <style is:inline>
    @font-face {
      font-family: 'Inter';
      font-style: normal;
      font-weight: 100 900;
      font-display: swap;
      src: url('/fonts/InterVariable.woff2') format('woff2-variations');
    }
  </style>
  <ClientRouter />
  <title>{title}</title>
  <meta name="description" content={description} />
  {canonical && <link rel="canonical" href={canonical} />}
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  {ogImage && <meta property="og:image" content={ogImage} />}
  <meta name="twitter:card" content={ogImage ? "summary_large_image" : "summary"} />
  {config.search_console_verification && (
    <meta name="google-site-verification" content={config.search_console_verification} />
  )}
  {config.ga4_id && (
    <>
      <script async src={`https://www.googletagmanager.com/gtag/js?id=${config.ga4_id}`}></script>
      <script set:html={`window.dataLayer = window.dataLayer||[];function gtag(){dataLayer.push(arguments);}gtag('js',new Date());gtag('config','${config.ga4_id}');`}></script>
    </>
  )}
  <slot name="head" />
</head>
<body class="bg-white text-slate-900">
  <Header />
  <main><slot /></main>
  <Footer />
</body>
</html>
